{
  "openapi": "3.0.0",
  "info": {
    "title": "Zenith API",
    "description": "Financial Intelligence Platform REST API",
    "version": "1.0.0",
    "contact": {
      "name": "Zenith API Support",
      "email": "api-support@zenith.local"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8200",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Authenticate user and get JWT token",
        "description": "Authenticate user and get JWT token",
        "parameters": [
          {
            "name": "username",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "admin"
            },
            "description": "username"
          },
          {
            "name": "password",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "admin123"
            },
            "description": "password"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "summary": "Register new user",
        "description": "Register new user",
        "parameters": [
          {
            "name": "email",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "user@example.com"
            },
            "description": "email"
          },
          {
            "name": "username",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "newuser"
            },
            "description": "username"
          },
          {
            "name": "password",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "password123"
            },
            "description": "password"
          },
          {
            "name": "full_name",
            "in": "json",
            "required": false,
            "schema": {
              "type": "string",
              "example": "New User"
            },
            "description": "full_name"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "summary": "Get all projects for current user",
        "description": "Get all projects for current user",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "post": {
        "summary": "Create new project",
        "description": "Create new project",
        "parameters": [
          {
            "name": "name",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "New Investigation"
            },
            "description": "name"
          },
          {
            "name": "description",
            "in": "json",
            "required": true,
            "schema": {
              "type": "string",
              "example": "Financial investigation case"
            },
            "description": "description"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/api/v1/users": {
      "get": {
        "summary": "Get all users (admin only)",
        "description": "Get all users (admin only)",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/api/v1/forensics": {
      "get": {
        "summary": "Get forensic analysis data",
        "description": "Get forensic analysis data",
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "example": "project_123"
            },
            "description": "project_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "System health check",
        "description": "System health check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}