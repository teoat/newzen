# Database Configuration
# Development (SQLite)
DATABASE_URL=sqlite:///./storage/zenith.db
# Production (PostgreSQL) - Uncomment for production
# DATABASE_URL=postgresql://username:password@localhost:5432/zenith_prod

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CONTEXT_DB=2

# Authentication & Security
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
ENCRYPTION_SECRET=CHANGE_THIS_ENCRYPTION_SECRET_32_CHARS_LONG
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Configuration (Zenith Copilot)
# Add multiple keys separated by commas for load balancing
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
GOOGLE_API_KEY=your_google_api_key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8200
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=./storage/uploads

# Feature Flags
ENABLE_PREDICTIVE_AI=true
ENABLE_SATELLITE_VERIFICATION=true

# Security Limits
PASSLIB_MAX_PASSWORD_SIZE=4096

# Environment
ENVIRONMENT=development
