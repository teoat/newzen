# Database Configuration
DATABASE_URL=postgresql://zenith:zenith@localhost:5442/zenith_lite

# Authentication
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration (Zenith Copilot)
GEMINI_API_KEYS=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Feature Flags
ENABLE_PREDICTIVE_AI=true
ENABLE_SATELLITE_VERIFICATION=true

# Security Limits
PASSLIB_MAX_PASSWORD_SIZE=4096

# System Monitoring & Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SENDGRID_API_KEY=SG.your_sendgrid_api_key
ALERT_EMAIL=ops@zenith.app

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_APP_VERSION=1.0.0

# Prometheus Metrics
PROMETHEUS_ENABLED=true

# Grafana Configuration
GRAFANA_URL=http://localhost:3100
GRAFANA_API_KEY=your-grafana-api-key
GRAFANA_ADMIN_PASSWORD=admin

# Alertmanager
PAGERDUTY_WEBHOOK_URL=https://events.pagerduty.com/v2/enqueue
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# SMTP Configuration (optional)
SMTP_HOST=localhost:25
SMTP_USERNAME=
SMTP_PASSWORD=

# Environment
ENV=development
